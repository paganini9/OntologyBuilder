# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Default LLM backend for pipelines: mock | gemini | anthropic | hf_local
LLM_BACKEND=mock

# Real keys (optional). If absent, backends auto-fall back to MOCK.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# HuggingFace (optional, for hf_local methods)
HF_HOME=.hf_cache
